# MySQL Configuration
MYSQL_ROOT_PASSWORD=password  # MySQL root şifresi (ÜRETİMDE DEĞİŞTİRİN!)
MYSQL_DATABASE=home-energy-tracker  # Veritabanı adı
DB_USERNAME=root  # application.properties için MySQL kullanıcı adı
DB_PASSWORD=password  # application.properties için MySQL şifresi (ÜRETİMDE DEĞİŞTİRİN!)

# InfluxDB Configuration
INFLUX_ADMIN_USERNAME=admin  # InfluxDB admin kullanıcı adı
INFLUX_ADMIN_PASSWORD=admin123  # InfluxDB admin şifresi (ÜRETİMDE DEĞİŞTİRİN!)
INFLUX_TOKEN=my-token  # InfluxDB API token (docker-compose ve application.properties'de kullanılır)
INFLUX_ORG=hba  # InfluxDB organizasyon adı (docker-compose ve application.properties'de kullanılır)
INFLUX_BUCKET=usage-bucket  # InfluxDB bucket adı (docker-compose ve application.properties'de kullanılır)

# Application Configuration
PACKAGE_NAME=com.hba  # Proje paket adı (Kafka type mapping için)
SENDER_EMAIL=template@example.com  # E-posta gönderen adresi (Alert Service)

# External Services
OLLAMA_MODEL=deepseek-coder  # Kullanılacak AI modeli (Insight Service)
OLLAMA_URL=http://localhost:11434  # Ollama sunucu adresi
USAGE_SERVICE_URL=http://localhost:8083/api/v1/usage  # Usage Service API adresi

# Simulation Configuration
SIMULATION_ENDPOINT=http://localhost:8082/api/v1/ingestion  # Simülasyon endpoint adresi
